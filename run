#!/usr/bin/env bash
set -euo pipefail

ROOT="$(cd "$(dirname "$0")" && pwd)"
PYTHON_BIN="${PYTHON_BIN:-python3}"
export MPLCONFIGDIR="${MPLCONFIGDIR:-$ROOT/results/.matplotlib}"
export CONSCIOUS_ACCESS_DATA_DIR="${CONSCIOUS_ACCESS_DATA_DIR:-$ROOT/data}"
export CONSCIOUS_ACCESS_RESULTS_DIR="${CONSCIOUS_ACCESS_RESULTS_DIR:-$ROOT/results}"
mkdir -p "$MPLCONFIGDIR" "$CONSCIOUS_ACCESS_RESULTS_DIR"

usage() {
  printf '%s\n' \
    "Usage:" \
    "  ./run validate" \
    "  ./run demo" \
    "  ./run prepare-data" \
    "  ./run notebook <01|02|03|04|05|06|name>" \
    "  ./run all" \
    "  ./run lab"
}

command="${1:-}"
case "$command" in
  validate)
    exec "$PYTHON_BIN" "$ROOT/scripts/validate_package.py"
    ;;
  demo)
    exec "$PYTHON_BIN" "$ROOT/scripts/demo.py"
    ;;
  prepare-data)
    exec "$PYTHON_BIN" "$ROOT/scripts/prepare_data.py" --data-dir "$CONSCIOUS_ACCESS_DATA_DIR"
    ;;
  notebook)
    if [[ $# -ne 2 ]]; then usage; exit 2; fi
    exec "$PYTHON_BIN" "$ROOT/scripts/run_notebook.py" "$2"
    ;;
  all)
    "$PYTHON_BIN" "$ROOT/scripts/prepare_data.py" --data-dir "$CONSCIOUS_ACCESS_DATA_DIR"
    for notebook in 01 02 03 04 05 06; do
      "$PYTHON_BIN" "$ROOT/scripts/run_notebook.py" "$notebook"
    done
    ;;
  lab)
    cd "$ROOT"
    exec "$PYTHON_BIN" -m jupyterlab
    ;;
  *)
    usage
    exit 2
    ;;
esac
